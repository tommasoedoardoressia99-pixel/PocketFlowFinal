    "serve:lakehouse-tunnel": "node scripts/lakehouse-public-tunnel.mjs",
    "aether:integrate": "node scripts/pocketflow-aether-integration.mjs",
    "aether:benchmark": "node scripts/pocketflow-aether-benchmark.mjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@solana/web3.js": "^1.98.4",
    "@tailwindcss/vite": "^4.1.14",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-react": "^5.0.4",
    "bip32": "^5.0.1",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^7.0.1",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
    "dotenv": "^17.2.3",
    "ecpair": "^3.0.1",
    "ed25519-hd-key": "^2.0.0",
    "ethers": "^6.17.0",
    "express": "^4.21.2",
    "imapflow": "^1.4.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "mailparser": "^3.9.12",
    "motion": "^12.23.24",
    "nodemailer": "^9.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tiny-secp256k1": "^2.2.4",
    "vite": "^6.2.3",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
